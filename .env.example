# Скопируйте этот файл как .env и заполните своими данными

# Supabase — берите в dashboard.supabase.com > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://ваш-проект.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=ваш-anon-key

# Telegram — токен вашего бота от @BotFather
EXPO_PUBLIC_TELEGRAM_BOT_TOKEN=ваш-токен-бота
