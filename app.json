{
  "expo": {
    "name": "КидРум",
    "slug": "kidroom-booking",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#EF9F27"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kidroom.booking",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Приложение использует геолокацию для построения маршрута до игровой комнаты.",
        "LSApplicationQueriesSchemes": ["yandexmaps", "comgooglemaps"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EF9F27"
      },
      "package": "com.kidroom.booking",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Приложение использует геолокацию для построения маршрута до игровой комнаты."
        }
      ]
    ],
    "scheme": "kidroom",
    "experiments": {
      "typedRoutes": false
    }
  }
}
